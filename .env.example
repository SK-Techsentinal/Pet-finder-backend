PORT=4000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/pet-finder

JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Render URL here once deployed.
# Expo Go / React Native apps send requests with no Origin header
# so they are always allowed regardless of this list.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://your-frontend.onrender.com

# Legacy single-origin fallback (still works if ALLOWED_ORIGINS is not set)
CLIENT_URL=http://localhost:3000

# ── Frontend env vars (add these to your React / Expo .env) ──
# Expo / React Native:
#   EXPO_PUBLIC_API_URL=https://your-backend.onrender.com
# Vite:
#   VITE_API_URL=https://your-backend.onrender.com
# Create React App:
#   REACT_APP_API_URL=https://your-backend.onrender.com

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# ── Email ─────────────────────────────────────────────────────
EMAIL_FROM=noreply@petfinder.app
RESEND_API_KEY=re_...
